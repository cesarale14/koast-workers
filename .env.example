# Copy to `.env` and fill in real values. .env is gitignored.

# Supabase — service role for direct DB access (bypasses RLS).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Postgres direct connection (used by db.py for psycopg2).
DATABASE_URL=postgresql://user:pass@host:5432/postgres

# Channex — channel manager API.
CHANNEX_API_KEY=
CHANNEX_API_URL=https://app.channex.io/api/v1

# Ticketmaster — events feed (market_sync).
TICKETMASTER_API_KEY=

# AirROI — market comps (market_sync). Currently paused via
# KOAST_DISABLE_AIRROI=true on Vercel; kept here for reference.
AIRROI_API_KEY=
