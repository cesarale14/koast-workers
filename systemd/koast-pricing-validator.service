[Unit]
Description=Koast Pricing Engine Validator (daily)
After=network.target

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/koast-workers
ExecStart=/usr/bin/python3 /home/ubuntu/koast-workers/pricing_validator.py
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
